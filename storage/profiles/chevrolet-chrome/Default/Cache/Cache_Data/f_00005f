    validation: function () {
        var _this = this;
        var filtered_rules = {
            rules: {
                terms: {
                    required: true
                },
                "terms-contact": {
                    required: true
                },
                "terms-platform": {
                    required: true
                }
            },
            messages: {
                terms: {
                    required: "Acepta términos y condiciones.",
                },
                "terms-contact": {
                    required: "Acepta términos y condiciones."
                },
                "terms-platform": {
                    required: "Acepta términos y condiciones."
                }
            },
        };

        // Run custom validation methods
        _this.validationMethods();

        if (GEOLOCATION) {
            _this.fields.push({ name: "geo-dealer" });
        }

        // Filter rules
        $.each(_this.fields, function (index, field) {
            if (typeof _this.objects[field.name] == "object") {
                if (typeof _this.objects[field.name].validation == "object") {
                    filtered_rules.rules[field.name] =
                        _this.objects[field.name].validation.rules;
                    filtered_rules.messages[field.name] =
                        _this.objects[field.name].validation.messages;
                    if (typeof field.required !== "undefined") {
                        if (field.name == "city" || field.name == "dealer") {
                            filtered_rules.rules[field.name].required_manual = true;
                        } else {
                            filtered_rules.rules[field.name].required = field.required == 1;
                        }
                    }
                }
            }
        });

        forms.$form
            .find('input[name="contact_preference"]')
            .on("change", function () {
                var isValid = $(this).valid();
                if (isValid) {
                    var $group = $(this).closest(".form-group");
                    $group.removeClass("is-invalid");
                    $group.find("span.error").remove();
                }
            });

        // Run validation function
        forms.validation = forms.$form.validate({
            blur: function (element) {
                // filter fields with onchange validation
                var show = typeof $(element).data("validate-onchange") == "undefined";
                if (!show) this.element(element);
            },
            onclick: function (element, ev) {
                // filter fields with onchange validation
                var show = typeof $(element).data("validate-onchange") == "undefined";
                if (show) return false;
            },
            rules: filtered_rules.rules,
            messages: filtered_rules.messages,
            ignore: "",
            errorElement: "span",
            errorPlacement: function (error, element) {
                error.addClass("invalid-feedback");
                if (element.is('[name="geo-dealer"]')) {
                    element.closest(".form-group").prepend(error);
                } else {
                    element.closest(".form-group").append(error);
                }
            },
            highlight: function (element, errorClass, validClass) {
                if ($(element).hasClass("summernote")) {
                    $(element).closest(".form-group").addClass("is-invalid");
                }
                $(element).addClass("is-invalid");
            },
            unhighlight: function (element, errorClass, validClass) {
                if ($(element).hasClass("summernote")) {
                    $(element).closest(".form-group").removeClass("is-invalid");
                }
                $(element).removeClass("is-invalid");
            },
            invalidHandler: function (form, validator) {
                if (!validator.numberOfInvalids()) return;

                var errors = [];
                $.each(validator.errorList, function (i, err) {
                    if (err.message !== "") {
                        errors.push(err.message);
                    }
                });
                digitalData.formInfo.errorMessage = errors.join(" | ");
                _satellite.track("error-message");

                var $element = $(validator.errorList[0].element);
                var step = $element.closest(".step").data("step");
                var current_step = forms.$form.find(".step:visible").data("step");

                if (step !== current_step) {
                    _this.toStep(current_step, step, function () {
                        scrollToInvalidField($element);
                    });
                } else {
                    scrollToInvalidField($element);
                }
            },
            submitHandler: function (form) {
                var $btn = $(".submit-button");
                const textButton = $btn.text();
                $btn.attr("disabled", "disabled");
                $btn.addClass("loading");
                $btn.find(".text").html("Enviando");

                var datos = forms.$form.serialize();
                datos += "&form=" + FORM_URL;
                if (forms.$form.find('[name="geo-dealer"]:checked').length) {
                    datos +=
                        "&geo-city=" +
                        forms.$form.find('[name="geo-dealer"]:checked').data("geoCity");
                }

                $.ajax({
                    type: "POST",
                    dataType: "json",
                    url: BASE_URL + "front/send",
                    data: datos,
                    success: function (msg) {
                        $btn.removeAttr("disabled");
                        $btn.removeClass("loading");
                        $btn.find(".text").html(textButton);

                        if (msg.action) {
                            _satellite.track("thank-you");
                            if (msg.thanks) {
                                // Add thank you view
                                $("#thank-you").html(msg.thanks);

                                // Hide steps
                                $(".steps").fadeOut(400);

                                // Hide copy content
                                if ($(".copy").length) $(".copy").fadeOut(400);

                                // Hide form
                                forms.$form.fadeOut(400, function () {
                                    // Show thank you view
                                    $("#thank-you").fadeIn(400);

                                    // Remove steps and form from DOM
                                    $(".steps").remove();
                                    forms.$form.remove();
                                });
                                setTimeout(function () {
                                    $(window).scrollTop(0);
                                }, 1000);

                                const options = {
                                    method: "POST",
                                    headers: {
                                        Accept: "application/json",
                                        "Content-Type": "application/json",
                                        Authorization: "m1exbSTPUpoVih4DDAzihikwvibwdSpk",
                                    },
                                    body: JSON.stringify({
                                        DealerNumberID: msg.contacto.bac,
                                        DealerTargetCountry: "Colombia",
                                        CountryNumberCode: "57",
                                        LocalNumber: msg.contacto.telephone,
                                        GivenName: msg.contacto.first_name,
                                        FamilyName: msg.contacto.last_name,
                                        PersonalDocument: msg.contacto.document,
                                        Email: msg.contacto.email,
                                        VehicleModel: msg.contacto.model,
                                        CustomerComments: "Live Store",
                                    }),
                                };

                                fetch(
                                    "https://gm-leads.beta-cs.blip.ai/blip/thank-you-page/contacts",
                                    options
                                )
                                    .then(function (response) {
                                        if (response.status == 202) {
                                            console.log("Lead was sent to Blip successfully");
                                        }
                                    })
                                    .catch(function (response) {
                                        console.log("There was a problem sending the lead to Blip");
                                    });
                            } else {
                                new Noty({
                                    text: "Su consulta ha sido enviada!",
                                    theme: "bootstrap-v4",
                                    type: "success",
                                    progressBar: true,
                                    layout: "bottomRight",
                                    timeout: 3000,
                                    closeWith: ["click", "button"],
                                }).show();
                            }
                        } else {
                            // Show notification
                            var message =
                                typeof msg.message !== "undefined" && msg.message.length > 0
                                    ? msg.message
                                    : "Lo siento, ocurrió un error al intentar procesar la información.";
                            new Noty({
                                text: message,
                                theme: "bootstrap-v4",
                                type: "error",
                                progressBar: true,
                                layout: "bottomRight",
                                timeout: 3000,
                                closeWith: ["click", "button"],
                            }).show();
                        }
                    },
                    error: function (msg) {
                        $btn.removeAttr("disabled");
                        $btn.removeClass("loading");
                        $btn.find(".text").html(textButton);

                        var message =
                            typeof msg.message !== "undefined" && msg.message.length > 0
                                ? msg.message
                                : "Lo siento, ocurrió un error al intentar procesar la información.";
                        new Noty({
                            text: message,
                            theme: "bootstrap-v4",
                            type: "error",
                            progressBar: true,
                            layout: "bottomRight",
                            timeout: 3000,
                            closeWith: ["click", "button"],
                        }).show();
                    },
                });
            },
        });
    },

