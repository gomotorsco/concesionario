/**
 * Detecta dispositivos Apple táctiles (iOS / iPadOS).
 * Incluye iPads modernos que se identifican como "MacIntel" con touch points.
 * Pensado para ser reutilizado en otros proyectos que embeban forms en iframe.
 */
function isAppleTouchDevice() {
    return (
      /iPad|iPhone|iPod/i.test(navigator.userAgent) ||
      (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1)
    );
}

/**
 * Hace scroll animado hasta el primer campo inválido de un formulario validado
 * con jQuery Validate. En iOS/iPadOS se omite el scroll a propósito: dentro de
 * un iframe responsive, el scroll manual provoca que la vista "suba" al error
 * y oculte los campos superiores (bug reportado en Safari iOS).
 *
 * @param {jQuery} $element  Campo inválido (ej: validator.errorList[0].element envuelto en $()).
 * @param {Object} [options]
 * @param {number} [options.offset=50]   Offset en px respecto al top del form-group.
 * @param {number} [options.duration=300] Duración de la animación.
 */
function scrollToInvalidField($element, options) {
    if (isAppleTouchDevice()) return;
    if (!$element || !$element.length) return;

    options = options || {};
    var offset = typeof options.offset === "number" ? options.offset : 50;
    var duration = typeof options.duration === "number" ? options.duration : 300;

    var $group = $element.closest(".form-group");
    if (!$group.length) return;

    $("html, body").animate(
      { scrollTop: $group.offset().top - offset },
      duration,
    );
}

