                                    $(".jelly-wrapper .content img").fadeIn(300);
                                }, 300);
                            });

                            setTimeout(function () {
                                $(".jelly-wrapper .content img").fadeOut(300, function () {
                                    $(".jelly-wrapper .content img").attr("src", image);
                                    setTimeout(function () {
                                        $(".jelly-wrapper .content img").fadeIn(300, function () {
                                            forms.objects.models.$selector.prop("disabled", false);
                                        });
                                    }, 300);
                                });
                            }, 2000);
                        }, 2000);
                    }

                    setTimeout(function () {
