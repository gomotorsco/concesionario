        forms.$form.find(".step button.previous").click(function () {
            var current_step = $(this).closest(".step").data("step");
            var prev_step = current_step - 1;

            if (
                $('.step[data-step="' + prev_step + '"] .button-no-visible')
                    .closest(".buttons")
