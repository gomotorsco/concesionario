                                },
                                dataType: "json",
                                success: function (resp) {
                                    if (resp.action) {
                                        resp.data = getDistanceRadio(resp.data);

                                        var options = '<ul class="mt-4">';
                                        $.each(resp.data, function (i, item) {
                                            if (item.cercano && item.geolocation) {
                                                options += "<li>";
                                                options += '    <label for="bac-' + item.id + '">';
                                                options +=
                                                    '        <input type="radio" name="geo-dealer" id="bac-' +
                                                    item.id +
                                                    '" value="' +
                                                    item.bac +
                                                    '" data-geo-city="' +
                                                    item.cities_id +
                                                    '">';
                                                options +=
                                                    '        <div class="content stat-button-link" data-dtm="select dealer:search">';
                                                if (item.location != null) {
                                                    options +=
                                                        '            <span class="name">' +
                                                        item.name +
                                                        " - " +
                                                        item.location +
                                                        "</span>";
                                                } else {
                                                    options +=
                                                        '            <span class="name">' +
                                                        item.name +
                                                        "</span>";
                                                }
                                                options +=
                                                    '            <span class="distance">' +
                                                    item.distance +
                                                    "km</span>";
                                                options += "        </div>";
                                                options += "    </label>";
                                                options += "</li>";
                                            }
                                        });

                                        options += "</ul>";

                                        $(".dealers-geolocation").addClass("with-results");

                                        if ($(".dealers-geolocation .results ul").is(":visible")) {
                                            $(".dealers-geolocation .results").html(options);
                                            $(".show-dealers-manual").fadeIn(300);
                                            setTimeout(function () {
                                                overlayScroll = OverlayScrollbars(
                                                    document.querySelector(
                                                        ".dealers-geolocation .results ul"
                                                    ),
                                                    {
                                                        autoUpdate: true,
                                                        updateOnLoad: "label",
                                                    }
                                                );
                                            });
                                        } else {
                                            $(".dealers-manual").addClass("only-geolocation");
                                            setTimeout(function () {
                                                $(".dealers-geolocation .results").html(options);
                                                $(".dealers-geolocation .results").slideDown(
                                                    400,
                                                    function () {
                                                        $(".show-dealers-manual").fadeIn(300);
                                                    }
                                                );

                                                setTimeout(function () {
                                                    overlayScroll = OverlayScrollbars(
                                                        document.querySelector(
                                                            ".dealers-geolocation .results ul"
                                                        ),
                                                        {
                                                            autoUpdate: true,
                                                            updateOnLoad: "label",
                                                        }
                                                    );
                                                });
                                            }, 500);
                                        }
                                    } else {
                                        $(".dealers-geolocation").removeClass("with-results");
                                        $(".dealers-geolocation .results").html(
                                            "No se encontraron resultados."
                                        );
                                    }

                                    // Update tabIndexes
                                    forms.updateTabIndex();

                                    // Remove manual validation errors
                                    $.each($(".dealers-manual select"), function (i, item) {
                                        $(item).valid();
                                    });
                                },
                            });
                        }
                    });
                };

                forms.$form.find(".geolocation").click(function () {
                    findLocation();
                });

                forms.$form.find(".show-dealers-manual").click(function (ev) {
                    ev.preventDefault();

                    forms.$form.find(".show-dealers-manual").fadeOut(300);
                    $(".dealers-geolocation .results").slideUp(400, function () {
                        $(".dealers-geolocation").removeClass("with-results");
                        forms.$form.find(".dealers-manual").removeClass("only-geolocation");
                    });
                });
            },
