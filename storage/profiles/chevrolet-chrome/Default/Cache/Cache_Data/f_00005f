                            } else {
                                forms.$form.find(".step button.next").removeClass("pulsate");
                            }
                        }, 500);
                    }
                );

                const getLocation = function (cb) {
                    var get = function () {
                        if (navigator.geolocation) {
                            return new Promise(function (resolve, reject) {
                                return navigator.geolocation.getCurrentPosition(
                                    resolve,
                                    reject
                                );
                            });
                        } else {
                            return new Promise(function (resolve) {
                                return resolve({});
                            });
                        }
                    };

                    get()
                        .then(function (position) {
                            cb({
                                lat: position.coords.latitude,
                                lng: position.coords.longitude,
                            });
                        })
                        .catch(function (error) {
                            cb(false);
                        });
                };

                var getDistanceRadio = function (dealers, cb) {
                    var sortByDistance = function (a, b) {
                        if (!a.distance) {
                            return 0;
                        }
                        if (a.distance < b.distance) {
                            return -1;
                        }
                        if (a.distance > b.distance) {
                            return 1;
                        }
                        return 0;
                    };
                    var round = function (number) {
                        return Math.round((number + Number.EPSILON) * 100) / 100;
                    };
                    var deg2rad = function (deg) {
                        return deg * (Math.PI / 180);
                    };
                    var calculate = function (from, to) {
                        var R = 6371; // Radius of the earth in km
                        var dLat = deg2rad(to.lat - from.lat); // deg2rad below
                        var dLon = deg2rad(to.lng - from.lng);
                        var a =
                            Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                            Math.cos(deg2rad(from.lat)) *
                            Math.cos(deg2rad(to.lat)) *
                            Math.sin(dLon / 2) *
                            Math.sin(dLon / 2);
                        var c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                        var d = R * c; // Distance in km
                        return d;
                    };

                    $.each(dealers, function (i, concesionario) {
                        if (
                            concesionario.lat !== "" &&
                            concesionario.lat !== 0 &&
                            concesionario.lng !== "" &&
                            concesionario.lng !== 0
                        ) {
                            dealers[i].geolocation = {
                                lat: dealers[i].lat,
                                lng: dealers[i].lng,
                            };

                            if (geolocation) {
                                let distance = calculate(geolocation, dealers[i].geolocation);
                                dealers[i].distance = Math.round(distance * 100) / 100;
                            }
                        } else {
                            dealers[i].geolocation = false;
                        }
                    });

                    dealers.sort(sortByDistance);

                    $.each(dealers, function (i, d) {
                        dealers[i].cercano = i < 10;
                    });

                    return dealers;
                };

                const findLocation = function () {
                    getLocation(function (myPosition) {
                        let modelElement = forms.objects.models?.$selector,
                            modelValue = modelElement ? modelElement.val() : null;
                        geolocation = myPosition;
                        let data = myPosition;
                        data.form = FORM_URL;
                        data.model = modelValue;

                        if (data) {
                            $.ajax({
                                url: BASE_URL + "front/getDealersByGeolocation",
                                type: "GET",
                                data: data,
                                headers: {
