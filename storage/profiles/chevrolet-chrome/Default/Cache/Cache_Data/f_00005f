    toStep: function (from, to, callback) {
        var $from_nav = $('.steps .item[data-step="' + from + '"]');
        var $from_div = forms.$form.find('.step[data-step="' + from + '"]');
        var $to_nav = $('.steps .item[data-step="' + to + '"]');
        var $to_div = forms.$form.find('.step[data-step="' + to + '"]');

        // To Next
        if (from < to) {
            $from_nav.removeClass("active").addClass("done");
            $to_nav.removeClass("pending").addClass("active");
            if ($from_nav.prev(".item").length) {
            }
        }

        // To Prev
        else {
            $.each($(".steps .item"), function (i, item) {
                if ($(item).data("step") >= from - 1) {
                    $(item).removeClass("done");
                }
            });
            $from_nav.removeClass("active").addClass("pending");
            $to_nav.removeClass("done pending").addClass("active");
            if ($to_nav.prev(".item").length) {
                $to_nav.prev(".item").addClass("done");
            }
        }

        $from_div.fadeOut(600, function () {
            $to_div.fadeIn(600, function () {
                if (typeof callback == "function") {
                    callback();
                }
            });
        });
    },

    // Register custom validation methods.
    validationMethods: function () {

        // CI
        jQuery.validator.addMethod("noRepeats", function (value, element) {
            return this.optional(element) || /^(?!.*(\d)\1{5,})[1-9]\d{6,9}$/.test(value);
        });

        // Email Validation
        jQuery.validator.addMethod("email_validation", function (value, element) {
            return (this.optional(element) || /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/.test(value));
        });

        // Patent
        jQuery.validator.addMethod("patent_validation", function (value, element) {
            return this.optional(element) || /^([a-zA-Z]{3}[0-9]{3})$/i.test(value);
        });

        // Adviser
        jQuery.validator.addMethod("adviser_validation", function (value, element) {
            return this.optional(element) || /^(00[1-9]|0[1-9][0-9]|100)$/.test(value);
        });

        // Only letters
        jQuery.validator.addMethod("onlyletters", function (value, element) {
            return (this.optional(element) || /^([A-Za-z áéíóúâêîôûñÑç])+$/i.test(value));
        });

        // Dealer manual required
        jQuery.validator.addMethod("required_manual", function (value, element) {
            return (
                $(element).val() !== "" ||
                ($(".dealers-manual").hasClass("only-geolocation") &&
                    $('[name="geo-dealer"]:checked').length == 1)
            );
        });

        // Dealer geolocation required
        jQuery.validator.addMethod(
            "required_geolocation",
            function (value, element) {
                return (
                    !$(".dealers-manual").hasClass("only-geolocation") ||
                    ($(".dealers-manual").hasClass("only-geolocation") &&
                        $('[name="geo-dealer"]:checked').length == 1)
                );
            }
        );

        // Not equal to 0
        jQuery.validator.addMethod(
            "notEqualToValue",
            function (value, element, param) {
                return this.optional(element) || value != param;
            }
        );

        // Exaclty length
        jQuery.validator.addMethod("exactlength", function (value, element, param) {
            return this.optional(element) || value.length == param;
        });

        // Start with a determinate character
        jQuery.validator.addMethod("startWith", function (value, element, param) {
            return this.optional(element) || value.charAt(0) == param;
        });

        // Birthday Validation
        jQuery.validator.addMethod("birthday_validation", function (value, element) {
            let birthday = $(element).datepicker('getDate');
            let now = Date.now();
            let timeDiff = Math.abs(now - birthday);
            let years = Math.floor((timeDiff / (1000 * 3600 * 24)) / 365);
            return years >= 18 ? true : false;
        });

        // Max Date Validation
        jQuery.validator.addMethod("max_date_validation", function (value, element) {
            let birthday = $(element).datepicker('getDate');
            let today = new Date();

            return today.getTime() < birthday.getTime() ? false : true;
        });

        // Min Date Validation
        jQuery.validator.addMethod("min_date_validation", function (value, element) {
            let date = $(element).datepicker('getDate');
            let subdate = date.getFullYear();

            return subdate < 1900 ? false : true;
        });

        // Instagram Validation
        jQuery.validator.addMethod("instagram_validation", function (value, element) {
            let user = $(element).val();
            return user.substring(0, 1) === '@' ? true : false;
        });
    },

