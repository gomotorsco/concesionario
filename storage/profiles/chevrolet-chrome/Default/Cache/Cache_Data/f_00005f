        forms.$form.find(".step button.next").click(function () {
            var valid = true;
            var current_step = $(this).closest(".step").data("step");
            var next_step = current_step + 1;

            var step_fields = $(this)
                .closest(".step")
                .find("input, select, textarea");
            $.each(step_fields, function (i, input) {
                if (!$(input).valid()) {
                    valid = false;
